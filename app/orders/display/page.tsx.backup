'use client';

import { useState, useEffect } from 'react';
import { createClient } from '@/lib/supabase/client';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Clock, ChefHat, Check, Edit2, Trash2, X } from 'lucide-react';

interface OrderWithItems {
  id: string;
  order_number: number;
  status: 'not_started' | 'cooking' | 'ready';
  total_amount: number;
  created_at: string;
  items: Array<{ 
    name: string; 
    quantity: number;
    menu_item_id: string;
    price: number;
  }>;
  order_items?: any[];
}

export default function DisplayPage() {
  const [orders, setOrders] = useState<OrderWithItems[]>([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const fetchOrders = async () => {
      try {
        const supabase = createClient();
        
        const { data, error } = await supabase
          .from('orders')
          .select(`
            id,
            order_number,
            status,
            total_amount,
            created_at,
            order_items (
              menu_item_id,
              quantity,
              menu_items (name)
            )
          `)
          .in('status', ['not_started', 'cooking', 'ready'])
          .order('created_at', { ascending: false });

        if (error) throw error;

        if (data) {
          const formattedOrders = data.map(order => ({
            ...order,
            items: order.order_items.map((item: any) => ({
              name: item.menu_items?.name || 'Unknown',
              quantity: item.quantity,
            })),
          }));
          setOrders(formattedOrders);
        }
      } catch (err) {
        console.error('Error fetching orders:', err);
      } finally {
        setLoading(false);
      }
    };

    fetchOrders();

    // Auto-refresh every 3 seconds
    const interval = setInterval(fetchOrders, 3000);
    return () => clearInterval(interval);
  }, []);

  const getStatusIcon = (status: string) => {
    switch (status) {
      case 'not_started':
        return <Clock className="w-5 h-5 text-yellow-500" />;
      case 'cooking':
        return <ChefHat className="w-5 h-5 text-orange-500" />;
      case 'ready':
        return <Check className="w-5 h-5 text-green-500" />;
      default:
        return null;
    }
  };

  const getStatusLabel = (status: string) => {
    switch (status) {
      case 'not_started':
        return 'Not Started';
      case 'cooking':
        return 'Cooking';
      case 'ready':
        return 'Ready';
      default:
        return status;
    }
  };

  const getStatusBgColor = (status: string) => {
    switch (status) {
      case 'not_started':
        return 'bg-yellow-50 border-yellow-200';
      case 'cooking':
        return 'bg-orange-50 border-orange-200';
      case 'ready':
        return 'bg-green-50 border-green-200';
      default:
        return 'bg-gray-50';
    }
  };

  const notStartedOrders = orders.filter(o => o.status === 'not_started');
  const cookingOrders = orders.filter(o => o.status === 'cooking');
  const readyOrders = orders.filter(o => o.status === 'ready');

  if (loading) {
    return (
      <div className="min-h-screen bg-gradient-to-br from-primary/5 to-accent/5 flex items-center justify-center">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-primary mx-auto mb-4"></div>
          <p className="text-muted-foreground">Loading orders...</p>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gradient-to-br from-primary/5 to-accent/5 p-6">
      <div className="max-w-6xl mx-auto">
        {/* Header */}
        <div className="mb-8 text-center">
          <h1 className="text-4xl font-bold text-foreground mb-2">Order Status Board</h1>
          <p className="text-muted-foreground">Your order will be ready soon</p>
        </div>

        {/* Status Sections */}
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
          {/* Ready Orders - First */}
          <div>
            <div className="flex items-center gap-2 mb-4">
              <Check className="w-6 h-6 text-green-500" />
              <h2 className="text-2xl font-bold text-foreground">Ready</h2>
              <span className="ml-auto bg-green-500 text-white px-3 py-1 rounded-full text-sm font-semibold">
                {readyOrders.length}
              </span>
            </div>
            <div className="space-y-3">
              {readyOrders.length === 0 ? (
                <div className="text-center py-8 text-muted-foreground">No ready orders</div>
              ) : (
                readyOrders.map(order => (
                  <Card key={order.id} className="bg-green-50 border-green-200 hover:shadow-lg transition-shadow">
                    <CardContent className="p-4">
                      <div className="flex justify-between items-start mb-3">
                        <div>
                          <p className="text-2xl font-bold text-green-700">#{order.order_number}</p>
                          <p className="text-xs text-muted-foreground">Ready to pickup</p>
                        </div>
                        <Check className="w-5 h-5 text-green-500" />
                      </div>
                      <div className="space-y-1">
                        {order.items.map((item, idx) => (
                          <p key={idx} className="text-sm text-foreground">
                            {item.quantity}× {item.name}
                          </p>
                        ))}
                      </div>
                    </CardContent>
                  </Card>
                ))
              )}
            </div>
          </div>

          {/* Cooking Orders */}
          <div>
            <div className="flex items-center gap-2 mb-4">
              <ChefHat className="w-6 h-6 text-orange-500" />
              <h2 className="text-2xl font-bold text-foreground">Cooking</h2>
              <span className="ml-auto bg-orange-500 text-white px-3 py-1 rounded-full text-sm font-semibold">
                {cookingOrders.length}
              </span>
            </div>
            <div className="space-y-3">
              {cookingOrders.length === 0 ? (
                <div className="text-center py-8 text-muted-foreground">No orders cooking</div>
              ) : (
                cookingOrders.map(order => (
                  <Card key={order.id} className="bg-orange-50 border-orange-200 hover:shadow-lg transition-shadow">
                    <CardContent className="p-4">
                      <div className="flex justify-between items-start mb-3">
                        <div>
                          <p className="text-2xl font-bold text-orange-700">#{order.order_number}</p>
                          <p className="text-xs text-muted-foreground">Being prepared</p>
                        </div>
                        <ChefHat className="w-5 h-5 text-orange-500 animate-pulse" />
                      </div>
                      <div className="space-y-1">
                        {order.items.map((item, idx) => (
                          <p key={idx} className="text-sm text-foreground">
                            {item.quantity}× {item.name}
                          </p>
                        ))}
                      </div>
                    </CardContent>
                  </Card>
                ))
              )}
            </div>
          </div>

          {/* Not Started Orders */}
          <div>
            <div className="flex items-center gap-2 mb-4">
              <Clock className="w-6 h-6 text-yellow-500" />
              <h2 className="text-2xl font-bold text-foreground">Waiting</h2>
              <span className="ml-auto bg-yellow-500 text-white px-3 py-1 rounded-full text-sm font-semibold">
                {notStartedOrders.length}
              </span>
            </div>
            <div className="space-y-3">
              {notStartedOrders.length === 0 ? (
                <div className="text-center py-8 text-muted-foreground">No pending orders</div>
              ) : (
                notStartedOrders.map(order => (
                  <Card key={order.id} className="bg-yellow-50 border-yellow-200 hover:shadow-lg transition-shadow">
                    <CardContent className="p-4">
                      <div className="flex justify-between items-start mb-3">
                        <div>
                          <p className="text-2xl font-bold text-yellow-700">#{order.order_number}</p>
                          <p className="text-xs text-muted-foreground">In queue</p>
                        </div>
                        <Clock className="w-5 h-5 text-yellow-500 animate-pulse" />
                      </div>
                      <div className="space-y-1">
                        {order.items.map((item, idx) => (
                          <p key={idx} className="text-sm text-foreground">
                            {item.quantity}× {item.name}
                          </p>
                        ))}
                      </div>
                    </CardContent>
                  </Card>
                ))
              )}
            </div>
          </div>
        </div>

        {/* Footer */}
        <div className="mt-8 text-center text-muted-foreground text-sm">
          <p>Auto-refreshing every 3 seconds</p>
        </div>
      </div>
    </div>
  );
}
